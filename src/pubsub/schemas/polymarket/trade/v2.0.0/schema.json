{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm-event-schema-platform/schemas/polymarket/trade/v2.0.0/schema.json",
  "title": "polymarket.trade.v2.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "event_version",
    "trade"
  ],
  "properties": {
    "event_type": {
      "const": "trade"
    },
    "event_version": {
      "const": "2.0.0"
    },
    "trade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_number",
        "timestamp",
        "transaction_hash",
        "wallet",
        "token_id",
        "condition_id",
        "side",
        "maker_amount",
        "taker_amount"
      ],
      "properties": {
        "block_number": {
          "type": "integer",
          "minimum": 0
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 UTC timestamp"
        },
        "transaction_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+$"
        },
        "wallet": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "token_id": {
          "type": "string"
        },
        "condition_id": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$",
          "description": "Identifies the Polymarket market this trade belongs to"
        },
        "side": {
          "type": "integer",
          "enum": [
            0,
            1
          ],
          "description": "0 = BUY, 1 = SELL"
        },
        "maker_amount": {
          "type": "integer",
          "minimum": 0
        },
        "taker_amount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}