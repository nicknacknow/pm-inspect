# Polygon WebSocket RPC endpoints
# Put multiple endpoints in priority order, comma-separated.
# Get one from: QuickNode, Alchemy, Infura, or other Polygon RPC providers
POLYGON_WSS_URLS=wss://your-first-polygon-wss-endpoint,wss://your-second-polygon-wss-endpoint

# Legacy single-endpoint fallback (optional)
POLYGON_WSS_URL=wss://your-polygon-wss-endpoint

# Redis Pub/Sub settings for event publishing
REDIS_URL=redis://localhost:6379/0
