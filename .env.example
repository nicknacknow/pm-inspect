# Polygon WebSocket RPC endpoints (comma-separated, ordered by priority)
# Get one from: QuickNode, Alchemy, Infura, or other Polygon RPC providers
# Falls back to POLYGON_WSS_URL for backwards compatibility
# POLYGON_WSS_URLS=wss://primary,wss://secondary
POLYGON_WSS_URL=wss://your-polygon-wss-endpoint


# Redis Pub/Sub settings for event publishing
REDIS_URL=redis://localhost:6379/0

# Prometheus metrics endpoint
METRICS_PORT=8001
